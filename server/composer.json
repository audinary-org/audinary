{
    "name": "audinary/api-backend",
    "description": "Audinary API Backend",
    "keywords": [
        "music",
        "api",
        "streaming",
        "mpd",
        "rest",
        "psr7"
    ],
    "homepage": "https://github.com/audinary-org/audinary",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Daniel Hiller & contributors",
            "email": "info@audinary.org",
            "homepage": "https://audinary.org"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-json": "*",
        "cboden/ratchet": "^0.4.4",
        "firebase/php-jwt": "6.10.0",
        "monolog/monolog": "^2.8",
        "php-di/php-di": "^7.0",
        "php-ffmpeg/php-ffmpeg": "^1.3",
        "phpmailer/phpmailer": "^6.10",
        "ramsey/uuid": "^4.7",
        "slim/psr7": "^1.5",
        "slim/slim": "^4.10"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.5.26",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "audit": {
            "block-insecure": true,
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    },
    "autoload": {
        "files": [
            "src/Helpers.php"
        ],
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "build": "composer install --no-dev --optimize-autoloader",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf"
    }
}