{
  "name": "audinary-client",
  "version": "1.1.0",
  "license": "AGPL-3.0",
  "type": "module",
  "description": "Audinary Vue.js Client Application",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "i18n:report": "vue-i18n-extract report --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/locales/*.json' --output './translation_report.json'",
    "i18n:remove": "vue-i18n-extract report --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/locales/*.json' --remove",
    "i18n:add": "vue-i18n-extract report --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/locales/*.json' --add"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.4.9",
    "flag-icons": "^7.5.0",
    "howler": "^2.2.3",
    "pinia": "^3.0.2",
    "three": "^0.180.0",
    "vue": "^3.5.16",
    "vue-i18n": "^11.1.5",
    "vue-router": "^4.5.1",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.17",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sass": "^1.89.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vue-eslint-parser": "^10.2.0",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "glob": "^11.0.0",
    "inflight": "npm:noop2@^2.0.0"
  }
}
